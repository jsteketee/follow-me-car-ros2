<?xml version="1.0"?>
<!--
  follow_me_car.urdf — physical description of the follow-me RC car.
  Chassis: Traxxas 1/16 Mini E-Revo (4WD monster truck).

  Two jobs:
    1. Gives robot_state_publisher the fixed joints it needs to put sensor frames
       (imu_link, uwb_link) on /tf_static, connecting them to base_link. Without this
       the IMU's frame_id dangles: messages reference a frame that isn't in the TF tree.
    2. Published on /robot_description, which Foxglove's 3D panel renders as a solid
       model of the car instead of a bare axis triad.

  Geometry is primitives only (box / cylinder) — no meshes. Mesh files would need
  package:// URIs, which Foxglove cannot resolve over the bridge. A monster truck
  therefore reads as: low chassis plate, body shell above it, four tall tires,
  generous ground clearance.

  Frame conventions (REP-103): x forward, y left, z up. base_link sits on the ground
  plane at the centre of the wheelbase, so z=0 is where the tyres touch.

  ===========================================================================
  DIMENSIONS (metres) — APPROXIMATE, from published E-Revo figures. MEASURE THE
  REAL CAR AND CORRECT THESE. Every `origin` below is derived from this table:

    overall length     0.324
    overall width      0.290   (across the tyres)
    wheelbase          0.216   -> wheel centres at x = +/- 0.108
    track              0.226   -> wheel centres at y = +/- 0.113
    tyre radius        0.048   (~96 mm diameter)
    tyre width         0.042
    ground clearance   0.030   -> chassis plate underside
  ===========================================================================
-->
<robot name="follow_me_car">

  <!-- ================= materials ================= -->
  <material name="chassis_grey">
    <color rgba="0.20 0.21 0.24 1.0"/>
  </material>
  <material name="body_red">
    <color rgba="0.80 0.12 0.12 1.0"/>
  </material>
  <material name="tyre_black">
    <color rgba="0.07 0.07 0.07 1.0"/>
  </material>
  <material name="sensor_teal">
    <color rgba="0.0 0.65 0.65 1.0"/>
  </material>
  <material name="uwb_orange">
    <color rgba="0.95 0.45 0.10 1.0"/>
  </material>

  <!-- =================================================================
       base_link — the robot's root frame. No geometry: it is the datum
       that odom -> base_link (from pose_estimator) attaches to.
       ================================================================= -->
  <link name="base_link"/>

  <!-- Chassis plate: the narrow tub the drivetrain bolts to, riding low
       between the tyres. Underside sits at the ground clearance height.
       Same length as the body shell (0.300) so neither overhangs the other.
       Extra visuals: four control arms reaching from the plate edge out to
       the wheel hubs (cosmetic only — they don't articulate with steering).
       Arm origins are in the CHASSIS frame (0.040 above base_link): wheel
       hubs sit at x +/-0.108, z 0.008 here; arms span plate edge (y 0.040)
       to the inner tyre face (y 0.092). -->
  <link name="chassis_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.300 0.080 0.020"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
    <visual>
      <origin xyz="0.108 0.066 0.004" rpy="0 0 0"/>
      <geometry>
        <box size="0.024 0.056 0.010"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
    <visual>
      <origin xyz="0.108 -0.066 0.004" rpy="0 0 0"/>
      <geometry>
        <box size="0.024 0.056 0.010"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
    <visual>
      <origin xyz="-0.108 0.066 0.004" rpy="0 0 0"/>
      <geometry>
        <box size="0.024 0.056 0.010"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
    <visual>
      <origin xyz="-0.108 -0.066 0.004" rpy="0 0 0"/>
      <geometry>
        <box size="0.024 0.056 0.010"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
  </link>
  <!-- plate centre = clearance (0.030) + half plate thickness (0.010) -->
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis_link"/>
    <origin xyz="0 0 0.040" rpy="0 0 0"/>
  </joint>

  <!-- Body shell: the painted lexan cab that gives the truck its silhouette.
       Sits above the plate and covers it in plan (0.300 x 0.170 over the
       0.300 x 0.080 plate), like the real body. Still inboard of the tyres
       (inner tyre faces at y = +/-0.092) so the wheels stay proud of it. -->
  <link name="body_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.300 0.170 0.070"/>
      </geometry>
      <material name="body_red"/>
    </visual>
  </link>
  <!-- shell centre = plate top (0.050) + half shell height (0.035) -->
  <joint name="base_to_body" type="fixed">
    <parent link="base_link"/>
    <child link="body_link"/>
    <origin xyz="0 0 0.085" rpy="0 0 0"/>
  </joint>

  <!-- =================================================================
       wheels — REAR wheels are FIXED joints (no per-wheel spin feedback, and
       wheel spin isn't worth rendering). FRONT wheels are REVOLUTE about z:
       a steer joint at each hub, driven live from /joint_states, which
       serial_bridge publishes from the telemetry `steering` value (normalized
       [-1, 1] scaled by the assumed +/-30 deg lock — see STEER_* constants
       there). Wheel SPIN stays unmodeled on all four.

       Cylinders are born about z, so rpy rolls them onto the y axis.
       Centres: x = +/-0.108 (wheelbase), y = +/-0.113 (track),
       z = tyre radius, which is what puts base_link on the ground.
       ================================================================= -->
  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.048" length="0.042"/>
      </geometry>
      <material name="tyre_black"/>
    </visual>
  </link>
  <!-- Steer about vertical at the hub. Limits are the ASSUMED +/-30 deg lock
       (0.5236 rad) — the real lock angle and the wire's steering sign are both
       uncalibrated (NOTES.md); correct limits here and STEER_SIGN in
       serial_bridge if the render mirrors reality. Velocity is a nominal RC
       servo slew (~400 deg/s). -->
  <joint name="base_to_front_left_wheel" type="revolute">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.108 0.113 0.048" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5236" upper="0.5236" effort="1.0" velocity="7.0"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.048" length="0.042"/>
      </geometry>
      <material name="tyre_black"/>
    </visual>
  </link>
  <joint name="base_to_front_right_wheel" type="revolute">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.108 -0.113 0.048" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5236" upper="0.5236" effort="1.0" velocity="7.0"/>
  </joint>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.048" length="0.042"/>
      </geometry>
      <material name="tyre_black"/>
    </visual>
  </link>
  <joint name="base_to_rear_left_wheel" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.108 0.113 0.048" rpy="0 0 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.048" length="0.042"/>
      </geometry>
      <material name="tyre_black"/>
    </visual>
  </link>
  <joint name="base_to_rear_right_wheel" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.108 -0.113 0.048" rpy="0 0 0"/>
  </joint>

  <!-- =================================================================
       imu_link — the frame serial_bridge stamps on sensor_msgs/Imu.
       THIS JOINT is what stops that frame from dangling. The offset is
       where the IMU chip physically sits relative to base_link; get it
       wrong and heading is still correct (yaw is unaffected by a pure
       translation) but any future accel-based work is biased.

       Mounted on TOP of the body shell at the REAR (the rear deck). Shell roof
       is at z = 0.120; z = 0.125 puts the box centre half its 0.010 height
       above that. x = -0.110 is the rear deck area; MEASURE both offsets.
       y = 0 assumes it is centred across the shell.

       rpy is zero, i.e. the board's axes are assumed aligned with the car's:
       chip +x forward, +z up. If the board is rotated or inverted on its mount,
       correct it HERE rather than adding an offset in code — that is exactly
       the misalignment this joint exists to express.
       ================================================================= -->
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.030 0.020 0.010"/>
      </geometry>
      <material name="sensor_teal"/>
    </visual>
  </link>
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.110 0 0.125" rpy="0 0 0"/>
  </joint>

  <!-- =================================================================
       uwb_link — the DW3000 AoA anchor. Mounted on a PAN SERVO, so this is a
       REVOLUTE joint (about z, at the mount) rather than fixed: the anchor
       rotates relative to the car to keep the tag in its ~+/-60 deg cone. The
       joint is driven live from /joint_states, published by serial_bridge from
       the telemetry pan_angle (see PAN_JOINT_NAME there).

       Putting the pan in the TF here means everything downstream composes for
       free: Foxglove renders the anchor at its true angle, and the chain
       odom -> base_link -> uwb_link -> tag_link yields the tag's absolute
       position with the pan already accounted for. The raw/fused bearings are
       sensor-relative (measured in this rotated frame) and need no separate pan
       term. The ~0.09 m lever arm is small next to the <10 cm ranging error,
       but it is not zero.

       Sits on the HOOD (front of the shell roof, z = 0.120): a long, thin
       board, long axis front-back, spinning on the pan servo beneath it.
       x = 0.090 is mid-hood; MEASURE the true pan-axis position — it IS the
       lever arm. The visual is dropped -0.006 so the 0.008-thick board rests
       on the hood while the frame origin stays at the pan axis (z = 0.130).
       ================================================================= -->
  <link name="uwb_link">
    <visual>
      <origin xyz="0 0 -0.006" rpy="0 0 0"/>
      <geometry>
        <box size="0.100 0.020 0.008"/>
      </geometry>
      <material name="uwb_orange"/>
    </visual>
  </link>
  <joint name="base_to_uwb" type="revolute">
    <parent link="base_link"/>
    <child link="uwb_link"/>
    <origin xyz="0.090 0 0.130" rpy="0 0 0"/>
    <!-- Pan about vertical at the mount. position (rad) is driven by serial_bridge
         as -radians(pan_angle): the wire's pan_angle is +right/CW, TF +z is +left/CCW.
         Limits are the firmware's symmetric PAN_MAX_DEG (+/-55 deg = +/-0.9599 rad);
         velocity is the 50 deg/s slew (0.8727 rad/s). -->
    <axis xyz="0 0 1"/>
    <limit lower="-0.9599" upper="0.9599" effort="1.0" velocity="0.8727"/>
  </joint>

</robot>
